<Application x:Class="MissionBossAot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MissionBossAot"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!--<v:ViewModelLocator x:Key="locator"/>-->
            <FontFamily x:Key="Iconfont">pack://application:,,,/MissionBoss;Fonts/#iconfont</FontFamily>
            <FontFamily x:Key="DigitalDisplay">pack://application:,,,/MissionBoss;Fonts/#Digital Display</FontFamily>

            <SolidColorBrush x:Key="CustomBackground3" Color="#FFF3F3F3" />
            <SolidColorBrush x:Key="CustomBackground6" Color="#FFF6F6F6" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsCustom.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsCustomDark.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsCustomGreen.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsCustomViolet.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsDefaultDark.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsDefault.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsCustomVioletDark.xaml"/>
                <ResourceDictionary Source="/Resources/Themes/Basic/Colors/ColorsDefaultViolet.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
