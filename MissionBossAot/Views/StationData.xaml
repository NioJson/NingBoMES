<Window x:Class="MissionBossAot.Views.StationData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        mc:Ignorable="d"
        Title="工站数据" Height="900" Width="1200" ShowInTaskbar="False"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="White"
        WindowStartupLocation="CenterScreen"
        Activated="Window_Activated"
        Name="StationDataCollect">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏区域 -->
        <Border Grid.Row="0" Background="#2C3E50" Height="50" CornerRadius="5">
            <Grid>
                <TextBlock Text="工站数据" FontSize="24" FontWeight="Bold" Foreground="White" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✕" Width="40" Height="35" HorizontalAlignment="Right" VerticalAlignment="Center" 
                Margin="0,0,10,0" Click="CloseButton_Click" FontSize="18" 
                Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 查询条件区域 - 所有条件在一行 -->
                <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,15" BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 开始时间标签 -->
                        <TextBlock Grid.Column="0" Text="开始时间：" FontSize="14" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="5,5,0,5"/>

                        <!-- 开始日期选择器 -->
                        <DatePicker x:Name="StartDatePicker" Grid.Column="1" Width="120" 
                                    VerticalAlignment="Center" Margin="5"/>

                        <!-- 开始时间文本框 -->
                        <TextBox x:Name="StartTimeTextBox" Grid.Column="2" Width="80" Text="00:00:00" 
                                 VerticalAlignment="Center" Margin="5" ToolTip="格式：HH:mm:ss"/>

                        <!-- 结束时间标签 -->
                        <TextBlock Grid.Column="3" Text="结束时间：" FontSize="14" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="15,5,0,5"/>

                        <!-- 结束日期选择器 -->
                        <DatePicker x:Name="EndDatePicker" Grid.Column="4" Width="120" 
                                    VerticalAlignment="Center" Margin="5"/>

                        <!-- 结束时间文本框 -->
                        <TextBox x:Name="EndTimeTextBox" Grid.Column="5" Width="80" Text="23:59:59" 
                                 VerticalAlignment="Center" Margin="5" ToolTip="格式：HH:mm:ss"/>

                        <!-- 工站名称标签 -->
                        <TextBlock Grid.Column="6" Text="工站名称：" FontSize="14" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="15,5,0,5"/>

                        <!-- 工站名称下拉框 -->
                        <ComboBox x:Name="StationComboBox" Grid.Column="7" Width="180" Height="30" 
                                  VerticalAlignment="Center" Margin="5" DisplayMemberPath="StationName" 
                                  SelectedValuePath="StationName" SelectionChanged="StationComboBox_SelectionChanged"/>

                        <!-- 按钮区域 -->
                        <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Button x:Name="QueryButton" Content="查询" Width="80" Height="30" 
                                    Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Margin="0,0,10,0" Click="QueryButton_Click"/>

                            <Button x:Name="ResetButton" Content="重置" Width="80" Height="30" 
                                    Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Margin="0,0,10,0" Click="ResetButton_Click"/>

                            <!-- 新增查看详情按钮 -->
                            <Button x:Name="DetailButton" Content="查看详情" Width="80" Height="30" 
                                    Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                    Click="DetailButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 表格区域 -->
                <Border Grid.Row="1" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid
                    Name="DataGrid_DataBaseData"
                    Background="White"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="False"
                    CanUserResizeRows="False"
                    CanUserSortColumns="False"
                    ColumnHeaderHeight="30"
                    EnableColumnVirtualization="True"
                    EnableRowVirtualization="True"
                    HorizontalScrollBarVisibility="Auto"
                    IsReadOnly="True"
                    RowHeight="30"
                    Style="{StaticResource DataGrid.Small}"
                    VerticalScrollBarVisibility="Auto" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>