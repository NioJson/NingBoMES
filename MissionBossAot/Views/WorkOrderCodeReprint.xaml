<Window x:Class="MissionBossAot.Views.WorkOrderCodeReprint"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        mc:Ignorable="d"
        Title="工单标签补打" Height="900" Width="1200" ShowInTaskbar="False"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="White"
        WindowStartupLocation="CenterScreen"
        Activated="Window_Activated"
        Name="WorkOrderCodeReprintForm">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏区域 -->
        <Border Grid.Row="0" Background="#2C3E50" Height="50" CornerRadius="5">
            <Grid>
                <TextBlock Text="工单标签补打" FontSize="24" FontWeight="Bold" Foreground="White" 
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✕" Width="40" Height="35" HorizontalAlignment="Right" VerticalAlignment="Center" 
            Margin="0,0,10,0" Click="CloseButton_Click" FontSize="18" 
            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 查询条件区域 - 工单号输入 -->
                <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,15" BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 工单号标签 -->
                        <TextBlock Grid.Column="0" Text="工单号：" FontSize="14" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="5,5,0,5"/>

                        <!-- 工单号输入框 -->
                        <TextBox x:Name="WorkOrderTextBox" Grid.Column="1" Width="200" Height="30"
                             VerticalAlignment="Center" Margin="5" ToolTip="请输入工单号"/>

                        <!-- 按钮区域 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Button x:Name="QueryButton" Content="查询" Width="80" Height="30" 
                                Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                                Margin="0,0,10,0" Click="QueryButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 表格区域 -->
                <Border Grid.Row="1" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid
                        Name="DataGrid_DataBaseData"
                        AutoGenerateColumns="False"
                        AlternatingRowBackground="LightGray"
                        AlternationCount="2"
                        Background="White"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="False"
                        CanUserResizeRows="False"
                        CanUserSortColumns="False"
                        ColumnHeaderHeight="30"
                        EnableColumnVirtualization="True"
                        EnableRowVirtualization="True"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        RowHeight="30"
                        Style="{StaticResource DataGrid.Small}"
                        VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <!-- 打印标签按钮列 -->
                            <DataGridTemplateColumn Header="操作" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="打印标签" Width="80" Height="25" 
                                                Background="#3498DB" Foreground="White" 
                                                BorderThickness="0" Cursor="Hand"
                                                Click="PrintLabelButton_Click"
                                                Tag="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="序号" Binding="{Binding RowNumber}" Width="60"/>
                            <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="Auto"/>
                            <DataGridTextColumn Header="型号" Binding="{Binding ModelText}" Width="Auto"/>
                            <DataGridTextColumn Header="下发流水号" Binding="{Binding FlowOrderId}" Width="Auto"/>
                            <DataGridTextColumn Header="工艺路线" Binding="{Binding RoutingText}" Width="Auto"/>
                            <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="Auto"/>
                            <DataGridTextColumn Header="订单数量" Binding="{Binding OrderAmount}" Width="Auto"/>
                            <DataGridTextColumn Header="返工码" Binding="{Binding WorkBackNo}" Width="Auto"/>

                            <DataGridTextColumn Header="工单状态" Binding="{Binding EnableStatus}" Width="Auto">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="6,3"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EnableStatus}" Value="已下发">
                                                <Setter Property="Background" Value="#C8E6C9"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EnableStatus}" Value="已完成">
                                                <Setter Property="Background" Value="#BBDEFB"/>
                                                <Setter Property="Foreground" Value="#1565C0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EnableStatus}" Value="未下发">
                                                <Setter Property="Background" Value="#E0E0E0"/>
                                                <Setter Property="Foreground" Value="#616161"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EnableStatus}" Value="挂起">
                                                <Setter Property="Background" Value="#FFF9C4"/>
                                                <Setter Property="Foreground" Value="#F57F17"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EnableStatus}" Value="异常">
                                                <Setter Property="Background" Value="#FFCDD2"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="创建时间" Binding="{Binding CreateDatetime}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>