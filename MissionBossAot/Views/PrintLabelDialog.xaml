<Window x:Class="MissionBossAot.Views.PrintLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        mc:Ignorable="d"
        Title="打印标签" 
        WindowStartupLocation="CenterOwner"
        Height="600" Width="800"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- 数据列表区域 - 占9/10高度 -->
        <DataGrid x:Name="PrintDataGrid" Grid.Row="0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选择" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="二维码内容" Binding="{Binding CodeString}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 按钮区域 - 占1/10高度
        <Button x:Name="SelectAllButton" Content="全选" Width="80" Height="30" 
        Margin="0,0,10,0" Click="SelectAllButton_Click"
        Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Margin="0,10,0,0">
            <Button x:Name="PrintButton" Content="打印标签" Width="80" Height="30" 
                    Margin="0,0,10,0" Click="PrintButton_Click"
                    Background="#2ECC71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="CloseButton" Content="关闭" Width="80" Height="30" 
                    Click="CloseButton_Click"
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
