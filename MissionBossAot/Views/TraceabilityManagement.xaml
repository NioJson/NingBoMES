<Window x:Class="MissionBossAot.Views.TraceabilityManagement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        mc:Ignorable="d"
        Title="追溯管理" Height="900" Width="1200" ShowInTaskbar="False"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="White"
        WindowStartupLocation="CenterScreen"
        Activated="Window_Activated" Name="TraceabilityManagementForm">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏区域 -->
        <Border Grid.Row="0" Background="#2C3E50" Height="50" CornerRadius="5">
            <Grid>
                <TextBlock Text="追溯管理" FontSize="24" FontWeight="Bold" Foreground="White" 
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✕" Width="40" Height="35" HorizontalAlignment="Right" VerticalAlignment="Center" 
            Margin="0,0,10,0" Click="CloseButton_Click" FontSize="18" 
            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 查询条件区域 - 所有条件在一行 -->
                <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,15" BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 最终码标签 -->
                        <TextBlock Grid.Column="5" Text="最终码：" FontSize="14" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="15,5,0,5"/>
                        <!-- 最终码文本框 -->
                        <TextBox x:Name="FinallyCode" Grid.Column="6" Width="300" Text="" 
     VerticalAlignment="Center" Margin="5" />


                        <!-- 按钮区域 -->
                        <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,0">
                            <Button x:Name="QueryButton" Content="查询" Width="80" Height="30" 
        Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
        Margin="0,0,10,0" Click="QueryButton_Click"/>

                            <Button x:Name="ResetButton" Content="从 P10 站读取二维码" Width="150" Height="30" 
        Background="#95A5A6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="10,0,10,0"
        Click="ResetButton_Click"/>

                            <!--                     <Button x:Name="CopyButton" Content="点击开始复制" Width="150" Height="30" 
Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
Margin="10,0,10,0" Click="CopyButton_Click"/> -->
                            

                            <!-- 新增：跳转至工单查询按钮 -->
                            <Button x:Name="NavigateToWorkOrderButton" Content="跳转至工单查询" Width="150" Height="30" 
        Background="#F39C12" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
        Click="NavigateToWorkOrderButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 表格区域 -->
                <Border Grid.Row="1" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid
                        AutoGenerateColumns="False"
                        Name="DataGrid_DataBaseData"
                        Grid.Row="2"
                        AlternatingRowBackground="LightGray"
                        AlternationCount="2"
                        Background="White"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="False"
                        CanUserResizeRows="False"
                        CanUserSortColumns="False"
                        ColumnHeaderHeight="30"
                        EnableColumnVirtualization="True"
                        EnableRowVirtualization="True"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        RowHeight="30"
                        Style="{StaticResource DataGrid.Small}"
                        VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" 
         Color="LightBlue"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="产品码" Binding="{Binding ProductCode}" Width="auto"/>
                            <DataGridTextColumn Header="电机码" Binding="{Binding MotorCode}" Width="auto" />
                            <DataGridTextColumn Header="过程码" Binding="{Binding ProcessCode}" Width="auto" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>