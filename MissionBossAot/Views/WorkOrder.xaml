<Window x:Class="MissionBossAot.Views.WorkOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        mc:Ignorable="d"
        Title="生产工单" Height="900" Width="1200" ShowInTaskbar="False"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="White"
        WindowStartupLocation="CenterScreen"
        Activated="Window_Activated"
        Name="WorkOrderManager">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <!-- 这个会占据所有剩余空间 -->
        </Grid.RowDefinitions>

        <!-- 标题栏区域 -->
        <Border Grid.Row="0" Background="#2C3E50" Height="50" CornerRadius="5">
            <Grid>
                <TextBlock Text="工单管理" FontSize="24" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✕" Width="40" Height="35" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Margin="0,0,10,0" Click="CloseButton_Click" FontSize="18" 
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- 上部分：工单录入 -->
        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="5" Padding="15" Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 录入表单区域 - 第一行 -->
                <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="工单号：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtWorkOrderNo" Height="30"/>
                    </StackPanel>

                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="型号：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbModel" Height="30"  
                                    DisplayMemberPath="Name" SelectionChanged="cmbModel_SelectionChanged">
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="下发流水号：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtIssueSerialNo" Height="30"/>
                    </StackPanel>

                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="工艺路线：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbProcessRoute" Height="30" DisplayMemberPath="Name">
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="产品名称：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtProductName" Height="30"/>
                    </StackPanel>

                    <!-- 工单开始时间 - 带时间选择 -->
                    <StackPanel Width="120" Margin="5">
                        <TextBlock Text="工单开始日期：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpStartDate" Height="30" SelectedDateFormat="Short"/>
                    </StackPanel>

                    <StackPanel Width="80" Margin="5">
                        <TextBlock Text="时间：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtStartTime" Text="08:00:00" Height="30"/>
                    </StackPanel>
                </WrapPanel>

                <!-- 录入表单区域 - 第二行 -->
                <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="订单数量：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtOrderQuantity" Height="30" PreviewTextInput="NumberValidationTextBox" />
                    </StackPanel>
                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="下线流水号：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtOfflineSerialNo" Height="30"/>
                    </StackPanel>

                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="返工码：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtReworkCode" Height="30"/>
                    </StackPanel>
                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="配方名称：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="txtFormulaName" Height="30" DisplayMemberPath="Name">
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Width="150" Margin="5">
                        <TextBlock Text="生产班组：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbProductionTeam" Height="30" DisplayMemberPath="Name">
                        </ComboBox>
                    </StackPanel>

                    <!-- 计划完成时间 - 带时间选择 -->
                    <StackPanel Width="120" Margin="5">
                        <TextBlock Text="计划完成日期：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpPlanCompleteDate" Height="30" SelectedDateFormat="Short"/>
                    </StackPanel>

                    <StackPanel Width="80" Margin="5">
                        <TextBlock Text="时间：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPlanCompleteTime" Text="17:00:00" Height="30"/>
                    </StackPanel>

                </WrapPanel>

                <!-- 录入表单区域 - 第三行 -->
                <WrapPanel Grid.Row="2" Margin="0,0,0,10">
                    <StackPanel Width="410" Margin="5">
                        <TextBlock Text="备注：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtRemark" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                    <StackPanel Width="700" Margin="5">
                        <TextBlock Text="执行工站：" FontWeight="Bold" Margin="0,0,0,5"/>
                        <WrapPanel x:Name="wpExecutionStation" Margin="0,5,0,0">
                        </WrapPanel>
                    </StackPanel>
                </WrapPanel>

                <!-- 按钮区域 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnClear" Content="清除数据" Width="100" Height="35" Margin="10" 
                            Click="ClearData_Click" Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnSave" Content="保存数据" Width="100" Height="35" Margin="10" 
                            Click="SaveData_Click" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnReseach" Content="刷新" Width="100" Height="35" Margin="10" 
                            Click="ReseachSettingData_Click" Background="#27AE90" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 下部分：工单列表 -->
        <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <!-- DataGrid会自动填充这个区域 -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 查询条件行 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：状态筛选 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="状态：" FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
                        <ComboBox x:Name="cmbStatus" Width="100" Height="30" Margin="5">
                            <ComboBoxItem Content="全部" IsSelected="True"/>
                            <ComboBoxItem Content="未下发"/>
                            <ComboBoxItem Content="已下发"/>
                            <ComboBoxItem Content="已完成"/>
                        </ComboBox>
                        <TextBlock Text="工单号：" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5,0,5"/>
                        <TextBox x:Name="txtWorkOrderNo_Search" Width="150" Height="30" Margin="5" VerticalAlignment="Center"/>
                        <TextBlock Text="产品名称：" FontWeight="Bold" VerticalAlignment="Center" Margin="10,5,0,5"/>
                        <TextBox x:Name="txtProductName_Search" Width="150" Height="30" Margin="5" VerticalAlignment="Center"/>
                        <Button Content="查询" Width="80" Height="35" Margin="20,0,0,0" 
                                Click="Search_Click" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- 数据表格 - 移除了固定的Height，让其自动填充 -->
                <DataGrid x:Name="dgWorkOrders" Grid.Row="1" AutoGenerateColumns="False" 
                          MinHeight="200"   
                    SelectionMode="Single" SelectionChanged="WorkOrder_SelectionChanged" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <!-- 垂直滚动条 -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="序号" Binding="{Binding RowNumber}" Width="60"/>
                        <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="Auto"/>
                        <DataGridTextColumn Header="型号" Binding="{Binding ModelText}" Width="Auto"/>
                        <DataGridTextColumn Header="下发流水号" Binding="{Binding FlowOrderId}" Width="Auto"/>
                        <DataGridTextColumn Header="工艺路线" Binding="{Binding RoutingText}" Width="Auto"/>
                        <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="Auto"/>
                        <DataGridTextColumn Header="订单数量" Binding="{Binding OrderAmount}" Width="Auto"/>
                        <DataGridTextColumn Header="返工码" Binding="{Binding WorkBackNo}" Width="Auto"/>

                        <DataGridTextColumn Header="工单状态" Binding="{Binding EnableStatus}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EnableStatus}" Value="已下发">
                                            <Setter Property="Background" Value="#C8E6C9"/>
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EnableStatus}" Value="已完成">
                                            <Setter Property="Background" Value="#BBDEFB"/>
                                            <Setter Property="Foreground" Value="#1565C0"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EnableStatus}" Value="未下发">
                                            <Setter Property="Background" Value="#E0E0E0"/>
                                            <Setter Property="Foreground" Value="#616161"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EnableStatus}" Value="挂起">
                                            <Setter Property="Background" Value="#FFF9C4"/>
                                            <Setter Property="Foreground" Value="#F57F17"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding EnableStatus}" Value="异常">
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreateDatetime}" Width="Auto"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding OrderStartDatetime}" Width="Auto"/>
                        <DataGridTextColumn Header="计划完成时间" Binding="{Binding PlanedCompleteDatetime}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0">
                    <Button x:Name="btnIssue" Content="下发工单" Width="100" Height="35" Margin="5" 
                            Click="IssueWorkOrder_Click" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                    <Button x:Name="btnDelete" Content="删除工单" Width="100" Height="35" Margin="5" 
                            Click="DeleteWorkOrder_Click" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>