<Window x:Class="MissionBossAot.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Models"
        mc:Ignorable="d"
        Title="MES" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 自定义标题栏/状态栏 -->
        <Border Grid.Row="0" Background="#2C3E50" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Height="35">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：系统信息和状态 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 应用图标 -->
                    <TextBlock Text="📋" FontSize="16" Foreground="White" Margin="10,0,5,0"/>
                    <TextBlock Text="MES系统" Foreground="White" FontSize="14" 
                               VerticalAlignment="Center" Margin="5,0,20,0"/>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="#555" Margin="10,0"/>

                    <!-- 状态信息 -->
                    <TextBlock Text="状态：" Foreground="White" Margin="10,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="运行中" Foreground="#3498DB" Margin="0,0,15,0" VerticalAlignment="Center"/>

                    <!-- 分隔线 -->
                    <Rectangle Width="1" Height="20" Fill="#555" Margin="10,0"/>

                    <!-- 时间显示 -->
                    <TextBlock x:Name="DateTimeText" Text="" Foreground="White" Margin="10,0,15,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右侧：登录信息和窗口按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 登录人员信息 -->
                    <Border Background="#34495E" CornerRadius="15" Padding="12,4,12,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="👤" FontSize="12" Foreground="White" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="UserInfoText" Text="张三" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <!-- 美化后的退出按钮 -->
                            <Button x:Name="LogoutBtn" 
                                Content="退出" 
                                Width="50" 
                                Height="26"
                                Cursor="Hand"
                                Click="LogoutBtn_Click">        
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="12"
                                        BorderThickness="0"
                                        Padding="10,0,10,0">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#C0392B"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#A93226"/>
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 窗口控制按钮 -->
                    <Button x:Name="MinimizeBtn" Content="─" Width="30" Height="30" 
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="16" Cursor="Hand" Click="MinimizeBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#555"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="MaximizeBtn" Content="□" Width="30" Height="30" 
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Click="MaximizeBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#555"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="CloseBtn" Content="✕" Width="30" Height="30" 
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Click="CloseBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E74C3C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主要内容区域 - 三列布局 -->
        <Border Grid.Row="1" Background="White" CornerRadius="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：打开的窗体缩略图列表 (10%宽度) -->
                <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#ECF0F1" Padding="12,10">
                            <TextBlock Text="打开的窗体" FontWeight="Bold" FontSize="13" Foreground="#2C3E50" 
                       TextAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="OpenWindowsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- 卡片样式 - 完全居中 -->
                                        <Border Margin="10,8,10,8" Padding="12,10" Background="White" 
                                                CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" 
                                                            Command="{Binding Command}" 
                                                            CommandParameter="{Binding CommandParameter}"/>
                                            </Border.InputBindings>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8F9FA"/>
                                                            <Setter Property="BorderBrush" Value="#3498DB"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <!-- 文本信息区域 - 居中 -->
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                                                   FontSize="12" Foreground="#2C3E50"
                                                                   TextAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 中间：可滚动卡片区域 (50%宽度) -->
                <Border Grid.Column="1" Background="#FAFAFA">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#ECF0F1" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="系统操作菜单" 
           FontWeight="Bold" FontSize="14" Foreground="#2C3E50"
           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                            <ItemsControl x:Name="CenterCardsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="0" Background="White" 
                CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- 标题区域 -->
                                                <Border Grid.Row="0" Background="{Binding Color}" 
                        CornerRadius="8,8,0,0" Padding="12,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                   FontSize="16" Foreground="White"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- 按钮列表区域 - 自动换行 -->
                                                <StackPanel Grid.Row="1" Margin="12,10">
                                                    <ItemsControl ItemsSource="{Binding Buttons}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Height="40"
                                                                        MinWidth="90"
                                                                        Background="White"
                                                                        BorderBrush="{Binding Color}"
                                                                        BorderThickness="1"
                                                                        Cursor="Hand"
                                                                        Command="{Binding Command}"
                                                                        CommandParameter="{Binding CommandParameter}"
                                                                        Margin="0,0,8,8">
                                                                    <Button.Content>
                                                                        <TextBlock Text="{Binding Text}" 
                                                                   TextWrapping="Wrap" 
                                                                   Foreground="{Binding Color}"
                                                                   FontSize="13"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                                    </Button.Content>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 右侧：可滚动卡片区域 (40%宽度) -->
                <Border Grid.Column="2" Background="#F5F5F5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#ECF0F1" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="任务列表" 
                                           FontWeight="Bold" FontSize="14" Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="RefreshBtn" Content="刷新" Width="60" 
                                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                                        Cursor="Hand" Click="RefreshBtn_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#95A5A6"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#7F8C8D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                            <ItemsControl x:Name="RightCardsList">
                                <ItemsControl.Resources>

                                    <!-- 普通卡片的模板 -->
                                    <DataTemplate DataType="{x:Type local:NormalCard}">
                                        <Border Margin="0,0,0,10" Padding="10" Background="White" 
                        CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" 
                        Cursor="Hand"
                                                MouseLeftButtonDown="NormalCard_MouseLeftButtonDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8F9FA"/>
                                                            <Setter Property="BorderBrush" Value="#3498DB"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <!-- 第一行：左侧圆形图标 + 中间标题 -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 左侧圆形图标 -->
                                                    <Border Grid.Column="0" Width="40" Height="40" 
                                    CornerRadius="20" Background="{Binding Color}" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding StationCount}" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Foreground="White" 
                                           FontWeight="Bold"
                                           FontSize="16"/>
                                                    </Border>

                                                    <!-- 中间标题和副标题 -->
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                                           FontSize="14" Foreground="#2C3E50"/>
                                                        <TextBlock Text="{Binding Subtitle}" FontSize="12" 
                                           Foreground="#888" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- 第二行：状态方块（水平滚动） -->
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Disabled"
                                      Margin="0,10,0,0">
                                                    <ItemsControl ItemsSource="{Binding StatusList}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding Color, FallbackValue='#FF6B6B'}"
                                                Margin="0,0,0,0" Padding="8,4">
                                                                    <TextBlock Text="{Binding Value, FallbackValue='优'}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="12"
                                                       TextWrapping="NoWrap"   
                                                       TextAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>



                                    <!-- 特殊卡片的模板 -->
                                    <DataTemplate DataType="{x:Type local:SpecialCard}">
                                        <Border Margin="0,0,0,10" Padding="15" Background="White" 
            CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="2" 
            Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#E6F3FF"/>
                                                            <Setter Property="BorderBrush" Value="#FF5733"/>
                                                            <Setter Property="BorderThickness" Value="3"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <StackPanel>
                                                <!-- 标题行 -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="Bold" 
                           FontSize="16" Foreground="#4A90E2"/>

                                                    <!-- 装饰图标 -->
                                                    <Border Grid.Column="1" Width="30" Height="30" 
                        CornerRadius="15" Background="{Binding IconColor, FallbackValue='#4A90E2'}"
                        Opacity="0.8">
                                                        <TextBlock Text="★" HorizontalAlignment="Center" 
                               VerticalAlignment="Center" Foreground="White"
                               FontSize="14" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>

                                                <!-- 分隔线 -->
                                                <Border Height="1" Background="#E0E0E0" Margin="0,10,0,10"/>

                                                <!-- 方框列表 - 使用WrapPanel实现自动换行 -->
                                                <WrapPanel Margin="0,5,0,10">
                                                    <ItemsControl ItemsSource="{Binding BoxItems}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <!-- 每个方框：60宽 x 80高，使用Grid实现右上角圆圈 -->
                                                                <Grid Width="60" Height="80" Margin="8,5">
                                                                    <!-- 方框主体 -->
                                                                    <Border Background="White" 
                                        CornerRadius="4"
                                        BorderBrush="#4A90E2" 
                                        BorderThickness="1.5"
                                        Cursor="Hand">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Background" Value="#F0F8FF"/>
                                                                                        <Setter Property="BorderBrush" Value="#FF5733"/>
                                                                                        <Setter Property="BorderThickness" Value="2.5"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>

                                                                        <!-- 方框内容 -->
                                                                        <StackPanel VerticalAlignment="Center" 
                                                HorizontalAlignment="Center">
                                                                            <TextBlock Text="{Binding Value}" 
                                                   FontSize="16" 
                                                   FontWeight="Bold" 
                                                   Foreground="#4A90E2"
                                                   HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Label}" 
                                                   FontSize="10" 
                                                   Foreground="#888"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,5,0,0"/>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <!-- 右上角绿色圆圈（角标） -->
                                                                    <Border Width="18" Height="18" 
                                        CornerRadius="9" 
                                        Background="{Binding TopRightColor}"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top"
                                        Margin="0,-5,-5,0">
                                                                        <Border.Effect>
                                                                            <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Opacity="0.3"/>
                                                                        </Border.Effect>
                                                                    </Border>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>


                                </ItemsControl.Resources>

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>






                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
