<Window x:Class="MissionBossAot.Views.WorkOrderQuery"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        mc:Ignorable="d"
        Title="工单查询" Height="900" Width="1200" ShowInTaskbar="False"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="White"
        WindowStartupLocation="CenterScreen"
        Name="WorkingOrderQuery">

    <Window.Resources>
        <!-- 测试数据项模板 - 用于每个统计卡片内部的测试指标 -->
        <DataTemplate x:Key="TestItemTemplate">
            <Border Background="#F0F3F8" CornerRadius="8" Width="100" Height="auto" Margin="0,0,12,12">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="12" Foreground="#666" Margin="0,0,0,5"
                               TextWrapping="Wrap" 
                               />
                    <TextBlock Grid.Row="1" Text="{Binding Value}" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" 
                               TextWrapping="Wrap" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 右侧统计卡片模板 -->
        <DataTemplate x:Key="StatisticsCardTemplate">
            <Border Background="White" CornerRadius="10" Margin="0,0,0,12" 
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 卡片标题栏（可点击折叠/展开） -->
                    <Border Grid.Row="0" Background="{Binding HeaderColor}" CornerRadius="10,10,0,0" 
                            Padding="15,12" Cursor="Hand" MouseLeftButtonDown="ToggleCardExpand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 图标 -->
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,12,0"/>

                            <!-- 标题 -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding CardTitle}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{Binding SubTitle}" FontSize="11" Foreground="White" Opacity="0.85" 
                                           Margin="0,3,0,0" Visibility="{Binding HasSubTitle}"/>
                            </StackPanel>

                            <!-- 展开/折叠箭头 -->
                            <TextBlock Grid.Column="2" Text="{Binding ArrowIcon}" FontSize="16" Foreground="White"/>
                        </Grid>
                    </Border>

                    <!-- 卡片内容区域（可折叠）- 使用WrapPanel实现每行三个测试指标 -->
                    <Border Grid.Row="1" Padding="15" Visibility="{Binding ContentVisibility}">
                        <ItemsControl ItemsSource="{Binding TestItems}" ItemTemplate="{StaticResource TestItemTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- 页面主容器，带内边距 -->
    <Grid Margin="10">
        <!-- 标题栏和内容区域的行定义 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏区域 -->
        <Border Grid.Row="0" Background="#2C3E50" Height="50" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <TextBlock Text="工单查询" FontSize="24" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Content="✕" Width="40" Height="35" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Margin="0,0,10,0" Click="CloseButton_Click" FontSize="18" 
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- 三块内容区域：三个列等宽且高度填满 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ==================== 左侧区域：工单查询列表 ==================== -->
            <Border Grid.Column="0" Background="#F8F9FA" CornerRadius="8" Margin="0,0,5,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 左侧标题 -->
                    <TextBlock Grid.Row="0" Text="工单查询" FontSize="18" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <!-- 查询条件区域 -->
                    <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <!-- 开始时间 -->
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="开始时间" FontSize="13" Foreground="#555" Margin="0,0,0,5"/>
                                <DatePicker x:Name="StartDatePicker" Width="Auto" Height="30" 
                                            SelectedDateFormat="Short" 
                                            FontSize="13" BorderBrush="#CCC" BorderThickness="1"/>
                                <TextBox x:Name="StartTimeBox" Text="00:00:00" Height="30" Margin="0,5,0,0" 
                                         FontSize="13" BorderBrush="#CCC" BorderThickness="1" Tag="时:分:秒"/>
                            </StackPanel>

                            <!-- 结束时间 -->
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="结束时间" FontSize="13" Foreground="#555" Margin="0,0,0,5"/>
                                <DatePicker x:Name="EndDatePicker" Width="Auto" Height="30" 
                                            SelectedDateFormat="Short" 
                                            FontSize="13" BorderBrush="#CCC" BorderThickness="1"/>
                                <TextBox x:Name="EndTimeBox" Text="23:59:59" Height="30" Margin="0,5,0,0" 
                                         FontSize="13" BorderBrush="#CCC" BorderThickness="1" Tag="时:分:秒"/>
                            </StackPanel>

                            <!-- 工单号 -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="工单号" FontSize="13" Foreground="#555" Margin="0,0,0,5"/>
                                <TextBox x:Name="WorkOrderNoBox" Height="32" FontSize="13" 
                                         BorderBrush="#CCC" BorderThickness="1" Padding="5"/>
                            </StackPanel>

                            <!-- 查询按钮 -->
                            <Button x:Name="SearchButton" Content="🔍 查询" Height="35" 
                                    Background="#3498DB" Foreground="White" FontSize="14" 
                                    BorderThickness="0" Cursor="Hand" Click="SearchWorkOrders_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 工单结果列表 -->
                    <!-- 表格区域 -->
                    <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <DataGrid
                            Name="DataGrid_DataBaseData"
                            SelectionChanged="DataGrid_DataBaseData_SelectionChanged"
                            AutoGenerateColumns="False"
                            Background="White"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="False"
                            CanUserResizeRows="False"
                            CanUserSortColumns="False"
                            ColumnHeaderHeight="30"
                            EnableColumnVirtualization="True"
                            EnableRowVirtualization="True"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            RowHeight="30"
                            Style="{StaticResource DataGrid.Small}"
                            VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding RowNumber}" Width="60"/>
                                <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="Auto"/>
                                <DataGridTextColumn Header="型号" Binding="{Binding ModelText}" Width="Auto"/>
                                <DataGridTextColumn Header="下发流水号" Binding="{Binding FlowOrderId}" Width="Auto"/>
                                <DataGridTextColumn Header="工艺路线" Binding="{Binding RoutingText}" Width="Auto"/>
                                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="Auto"/>
                                <DataGridTextColumn Header="订单数量" Binding="{Binding OrderAmount}" Width="Auto"/>
                                <DataGridTextColumn Header="返工码" Binding="{Binding WorkBackNo}" Width="Auto"/>

                                <DataGridTextColumn Header="工单状态" Binding="{Binding EnableStatus}" Width="Auto">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EnableStatus}" Value="已下发">
                                                    <Setter Property="Background" Value="#C8E6C9"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EnableStatus}" Value="已完成">
                                                    <Setter Property="Background" Value="#BBDEFB"/>
                                                    <Setter Property="Foreground" Value="#1565C0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EnableStatus}" Value="未下发">
                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                    <Setter Property="Foreground" Value="#616161"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EnableStatus}" Value="挂起">
                                                    <Setter Property="Background" Value="#FFF9C4"/>
                                                    <Setter Property="Foreground" Value="#F57F17"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EnableStatus}" Value="异常">
                                                    <Setter Property="Background" Value="#FFCDD2"/>
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="创建时间" Binding="{Binding CreateDatetime}" Width="Auto"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <!-- ==================== 中间区域：过程码查询 ==================== -->
            <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="8" Margin="5,0,5,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 中间标题 -->
                    <TextBlock Grid.Row="0" Text="过程码查询" FontSize="18" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <!-- 查询条件区域 -->
                    <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="过程码" FontSize="13" Foreground="#555" Margin="0,0,0,5"/>
                            <TextBox x:Name="ProcessCodeBox" Height="32" FontSize="13" 
                                     BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,15"/>
                            <Button x:Name="SearchProcessButton" Content="🔍 查询过程码" Height="35" 
                                    Background="#9B59B6" Foreground="White" FontSize="14" 
                                    BorderThickness="0" Cursor="Hand" Click="SearchProcessCode_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 过程码结果 (条状卡片列表) -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProcessResultPanel" Margin="0,5,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 条状卡片样式 -->
                                    <Border Background="White" CornerRadius="6" Margin="0,0,0,8" 
                                            Padding="10,8" BorderBrush="#DDD" BorderThickness="1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="ProcessCard_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 左侧状态颜色指示条 -->
                                            <Border Grid.Column="0" Width="5" Background="{Binding StatusColor}" 
                                                    CornerRadius="3" Margin="0,0,10,0"/>

                                            <!-- 主要内容区域 -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding ProcessName}" FontSize="15" FontWeight="Bold" Foreground="#2C3E50"/>
                                            </StackPanel>

                                            <!-- 右侧标识 -->
                                            <Border Grid.Column="2" Background="{Binding TagColor}" CornerRadius="10" 
                                                    Padding="8,4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TagText}" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ==================== 右侧区域：卡片数据展示（后端动态生成） ==================== -->
            <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="8" Margin="5,0,0,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 右侧标题 -->
                    <TextBlock Grid.Row="0" Text="工站数据看板" FontSize="18" FontWeight="SemiBold" 
                               Foreground="#2C3E50" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                    <!-- 垂直卡片列表区域 - 完全由后端数据驱动 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="StatisticsCardsControl" 
                                      ItemTemplate="{StaticResource StatisticsCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>