<Window x:Class="MissionBossAot.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MissionBossAot.Views"
        xmlns:common="clr-namespace:MissionBossAot.Common"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="用户登录"
        Width="700"
        Height="437"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        mc:Ignorable="d">
    
    <hc:TransitioningContentControl TransitionMode="Left2RightWithFade">
        <Grid Background="Transparent" Margin="-1,5,1,-5">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseLeftButtonDown">
                    <i:InvokeCommandAction Command="{Binding WindowMoveCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="263" />
                <ColumnDefinition Width="437" />
            </Grid.ColumnDefinitions>
            <Border
            Grid.RowSpan="2"
            Background="#5a88d3"
            CornerRadius="{Binding ElementCornerRadius}"
              />
            <Border
            Grid.RowSpan="2"
            Grid.Column="1"
            Background="#FFF6F6F6"
            BorderBrush="{Binding LoginTheme}"
            BorderThickness="1"
            CornerRadius="{Binding ElementCornerRadius}" />
            <StackPanel Orientation="Horizontal">
                <Image
            Width="18"
            Height="18"
            Margin="8,0,8,0"
            RenderOptions.BitmapScalingMode="Fant"
            Source="/MissionBossAot;component/Resources/Images/WhiteImages/登录白128.png"/>
                <TextBlock
            VerticalAlignment="Center"
            Foreground="White"
            Text="MES-账号登录" />
            </StackPanel>
            <TextBlock
            Grid.RowSpan="2"
            Margin="0,10,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="White"
            LineHeight="30"
            Text="选择你的账号名称&#x000A;并且&#x000A;输入你的账号密码&#x000A;然后&#x000A;登录系统" />
            <StackPanel
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            Margin="0,1,1,1"
            Background="Transparent"
            Orientation="Vertical">
                <Button
                x:Name="Button_Close"
                Width="40"
                Height="30"
                HorizontalAlignment="Right"
                hc:BorderElement.CornerRadius="{Binding ElementCornerRadiusCloseButton}"
                hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                hc:IconElement.Height="12"
                hc:IconElement.Width="12"
                Background="Transparent"
                BorderBrush="Transparent"
                Command="{Binding LoginFormCloseCommand}"
                Foreground="Gray"
                MouseEnter="Button_Close_MouseEnter"
                MouseLeave="Button_Close_MouseLeave"
                ToolTip="关闭" />
                <Image
                Width="80"
                Height="80"
                Margin="0,30,0,0"
                RenderOptions.BitmapScalingMode="Fant"
                Source="/MissionBossAot;component/Resources/Images/系统白256.png" />
                <hc:ComboBox
                Name="ComboBox_UserName"
                Width="320"
                Height="30"
                Margin="0,30,0,0"
                hc:BorderElement.CornerRadius="{Binding SystemFrameworkElementCornerRadius}"
                hc:InfoElement.Placeholder="请选择你的账号名称"
                hc:TitleElement.Title="账号名称"
                hc:TitleElement.TitlePlacement="Left"
                hc:TitleElement.TitleWidth="70"
                BorderBrush="{Binding UserLoginFormUserName}"
                IsReadOnly="False"
                ItemsSource="{Binding DictionaryUserParemeters.Keys}"
                SelectedValue="{Binding UserAccount}">
                    <i:Interaction.Triggers>
                    </i:Interaction.Triggers>
                </hc:ComboBox>
                <hc:PasswordBox
                Name="PasswordBox_UserPassword"
                Width="320"
                Height="30"
                Margin="0,20,0,0"
                hc:BorderElement.CornerRadius="{Binding SystemFrameworkElementCornerRadius}"
                hc:InfoElement.Placeholder="请输入你的账号密码"
                hc:InfoElement.ShowClearButton="True"
                hc:TitleElement.Title="账号密码"
                hc:TitleElement.TitlePlacement="Left"
                hc:TitleElement.TitleWidth="70"
                BorderBrush="{Binding UserLoginFormUserName}"
                InputMethod.IsInputMethodEnabled="False"
                Password="123456"
                ShowEyeButton="True" />
                <TextBlock
                Margin="0,20,60,0"
                HorizontalAlignment="Right"
                Cursor="Hand"
                Style="{StaticResource TextBlockDefaultWarning}"
                Text="忘记密码？">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseLeftButtonDown">
                        <i:InvokeCommandAction Command="{Binding LoginForgetUserPasswordCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                </TextBlock>
                <Button
                Name="Button_Confirm"
                Width="320"
                Height="30"
                MinWidth="100"
                Margin="0,60,0,0"
                HorizontalAlignment="Stretch"
                hc:BorderElement.CornerRadius="{Binding SystemFrameworkElementCornerRadius}"
                Background="#5a88d3"
                BorderBrush="{Binding ElementCornerRadius}"
                Content="登录(Enter)"
                Click="Button_Confirm_Click"
                Foreground="White" />
            </StackPanel>
        </Grid>
    </hc:TransitioningContentControl>
</Window>
